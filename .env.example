# ── LLM ──────────────────────────────────────────────────────────────────────
# Required for LLM reasoning (M10). Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model used for chain analysis. claude-sonnet-4-6 recommended for cost/quality balance.
# Use claude-opus-4-8 for highest reasoning quality on complex business logic chains.
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096

# Cache LLM responses to disk to avoid re-paying for identical sub-graph analyses.
# Highly recommended during development. Cache stored at LLM_CACHE_DIR.
LLM_CACHE_ENABLED=true
LLM_CACHE_DIR=.cache/llm

# ── Neo4j ─────────────────────────────────────────────────────────────────────
# Matches docker-compose.yml defaults. Change NEO4J_PASSWORD here AND in docker-compose.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=attackpath

# ── Analysis ──────────────────────────────────────────────────────────────────
# Maximum candidate chains sent to LLM per analysis. Higher = more thorough, more cost.
MAX_CANDIDATES_PER_ANALYSIS=20

# Maximum JSON Schema nesting depth before truncation (DoS prevention).
MAX_SCHEMA_DEPTH=8

# Chains with final confidence below this threshold are excluded from reports.
CONFIDENCE_THRESHOLD=0.4

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG shows Cypher queries, LLM prompts, and token usage per chain.
LOG_LEVEL=INFO

# ── Optional API server (api-analyzer serve) ──────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Leave blank to disable API key authentication on the serve endpoint.
API_KEY=
