<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ ctx.analysis.spec_title }} — API Security Report</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
           margin: 0; background: #f8fafc; color: #1e293b; }
    a { color: #2563eb; }
    code { background: #f1f5f9; padding: 1px 4px; border-radius: 3px;
           font-family: "JetBrains Mono", "Fira Code", monospace; font-size: .85em; }

    /* ── Layout ── */
    .page { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
    section, article { margin-bottom: 2.5rem; }

    /* ── Header ── */
    header { background: #0f172a; color: #f8fafc; padding: 2rem 1.5rem; }
    header h1 { margin: 0 0 .25rem; font-size: 1.75rem; }
    header .meta { font-size: .875rem; opacity: .75; margin: 0; }

    /* ── Cards ── */
    .cards { display: flex; gap: 1rem; flex-wrap: wrap; margin: 1rem 0; }
    .card { flex: 1 1 140px; border-radius: 8px; padding: 1rem 1.25rem;
            text-align: center; color: #fff; }
    .card .num { font-size: 2rem; font-weight: 700; line-height: 1; }
    .card .lbl { font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; opacity: .9; }
    .card.critical { background: #dc2626; }
    .card.high     { background: #ea580c; }
    .card.medium   { background: #ca8a04; }
    .card.low      { background: #2563eb; }
    .card.info     { background: #6b7280; }
    .card.neutral  { background: #334155; }

    /* ── Tables ── */
    table { width: 100%; border-collapse: collapse; font-size: .9rem; }
    th, td { text-align: left; padding: .5rem .75rem; border-bottom: 1px solid #e2e8f0; }
    th { background: #f1f5f9; font-weight: 600; }
    tr:last-child td { border-bottom: none; }

    /* ── Severity badges ── */
    .badge { display: inline-block; padding: .2rem .6rem; border-radius: 4px;
             font-size: .75rem; font-weight: 700; text-transform: uppercase; color: #fff; }
    .badge.critical, tr.critical .sev { background: #dc2626; }
    .badge.high,     tr.high .sev     { background: #ea580c; }
    .badge.medium,   tr.medium .sev   { background: #ca8a04; }
    .badge.low,      tr.low .sev      { background: #2563eb; }
    .badge.info,     tr.info .sev     { background: #6b7280; }
    .sev { color: #fff; padding: .2rem .5rem; border-radius: 3px; font-size: .8rem; font-weight: 600; }

    /* ── Finding articles ── */
    .finding { background: #fff; border-radius: 8px; padding: 1.5rem;
               border-left: 5px solid #cbd5e1; box-shadow: 0 1px 3px rgba(0,0,0,.07); }
    .finding.critical { border-left-color: #dc2626; }
    .finding.high     { border-left-color: #ea580c; }
    .finding.medium   { border-left-color: #ca8a04; }
    .finding.low      { border-left-color: #2563eb; }
    .finding h2 { margin: 0 0 .5rem; font-size: 1.15rem; }
    .finding-meta { display: flex; gap: .5rem; flex-wrap: wrap;
                    align-items: center; font-size: .85rem; margin-bottom: 1rem; }
    .finding-meta span { background: #f1f5f9; padding: .2rem .5rem; border-radius: 4px; }
    .narrative { line-height: 1.7; color: #334155; }

    /* ── Steps ── */
    .steps { padding-left: 0; list-style: none; }
    .step { margin-bottom: 1rem; padding: 1rem; background: #f8fafc;
            border-radius: 6px; border: 1px solid #e2e8f0; }
    .step strong { display: block; margin-bottom: .5rem; font-size: .95rem; }
    .step table { font-size: .85rem; }
    .step th { width: 130px; background: none; font-size: .8rem; }

    /* ── Remediation ── */
    ol.remediation { padding-left: 1.25rem; }
    ol.remediation li { margin-bottom: .4rem; }

    /* ── MITRE / details ── */
    .mitre { font-size: .875rem; color: #475569; }
    details { margin-top: 1rem; }
    details summary { cursor: pointer; font-weight: 600; font-size: .9rem;
                      color: #475569; user-select: none; }
    details[open] summary { margin-bottom: .5rem; }
    .analyzed-at { font-size: .75rem; color: #94a3b8; margin-top: 1rem; }

    /* ── Graph ── */
    #attack-graph-container { background: #0f172a; border-radius: 8px;
                               overflow: hidden; height: 520px; position: relative; }
    #attack-graph { width: 100%; height: 100%; }
    .graph-empty { color: #94a3b8; text-align: center; padding: 3rem; }

    /* ── Footer ── */
    footer { text-align: center; font-size: .8rem; color: #94a3b8;
             padding: 2rem 0; border-top: 1px solid #e2e8f0; }
  </style>
</head>
<body>

<header>
  <div class="page">
    <h1>API Attack Path Analysis</h1>
    <p class="meta">
      {{ ctx.analysis.spec_title }} v{{ ctx.analysis.spec_version }}
      &nbsp;·&nbsp; Generated {{ ctx.generated_at.strftime('%Y-%m-%d %H:%M UTC') }}
      &nbsp;·&nbsp; api-attack-path-analyzer {{ ctx.tool_version }}
    </p>
  </div>
</header>

<div class="page">

  {# ── Executive Summary ── #}
  <section id="summary">
    <h2>Executive Summary</h2>

    <div class="cards">
      <div class="card critical"><div class="num">{{ ctx.analysis.critical_count }}</div><div class="lbl">Critical</div></div>
      <div class="card high">   <div class="num">{{ ctx.analysis.high_count }}</div>   <div class="lbl">High</div></div>
      <div class="card medium"> <div class="num">{{ ctx.analysis.medium_count }}</div> <div class="lbl">Medium</div></div>
      <div class="card low">    <div class="num">{{ ctx.analysis.low_count }}</div>    <div class="lbl">Low</div></div>
      <div class="card neutral"><div class="num">{{ ctx.analysis.candidates_evaluated }}</div><div class="lbl">Candidates Evaluated</div></div>
      <div class="card neutral"><div class="num">{{ ctx.analysis.endpoint_count }}</div><div class="lbl">Endpoints</div></div>
    </div>

    <table>
      <tr><th>Spec</th>            <td>{{ ctx.analysis.spec_title }} v{{ ctx.analysis.spec_version }} ({{ ctx.analysis.spec_format }})</td></tr>
      <tr><th>Spec completeness</th><td>{{ (ctx.analysis.spec_completeness * 100)|round(1) }}%</td></tr>
      <tr><th>Validated findings</th><td>{{ ctx.analysis.chain_count }}</td></tr>
      <tr><th>Candidates rejected</th><td>{{ ctx.analysis.candidates_rejected }}</td></tr>
      <tr><th>Duration</th>        <td>{{ ctx.analysis.duration_seconds|round(1) }}s</td></tr>
      <tr><th>LLM tokens used</th> <td>{{ ctx.analysis.llm_tokens_used }}</td></tr>
      <tr><th>Estimated cost</th>  <td>${{ "%.4f"|format(ctx.analysis.estimated_cost_usd) }}</td></tr>
      {% if ctx.analysis.highest_severity %}
      <tr><th>Highest severity</th><td><span class="badge {{ ctx.analysis.highest_severity|lower }}">{{ ctx.analysis.highest_severity }}</span></td></tr>
      {% endif %}
    </table>
  </section>

  {# ── Findings Summary Table ── #}
  {% if ctx.chain_summaries %}
  <section id="summary-table">
    <h2>Findings Summary</h2>
    <table>
      <thead>
        <tr>
          <th>#</th><th>Name</th><th>Severity</th><th>OWASP</th>
          <th>Confidence</th><th>Entry</th><th>Exit</th>
        </tr>
      </thead>
      <tbody>
      {% for s in ctx.chain_summaries %}
        <tr class="{{ s.severity|lower }}">
          <td>{{ loop.index }}</td>
          <td><a href="#finding-{{ s.id }}">{{ s.name }}</a></td>
          <td><span class="sev {{ s.severity|lower }}">{{ s.severity }}</span></td>
          <td>{{ s.owasp }}</td>
          <td>{{ (s.confidence * 100)|round(1) }}%</td>
          <td><code>{{ s.entry }}</code></td>
          <td><code>{{ s.exit_point }}</code></td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  {# ── Attack Path Graph ── #}
  {% if ctx.include_graph %}
  <section id="graph">
    <h2>Attack Path Graph</h2>
    {% if ctx.analysis.chain_count > 0 %}
    <div id="attack-graph-container">
      <svg id="attack-graph"></svg>
    </div>
    {% else %}
    <p class="graph-empty">No validated attack chains — graph not rendered.</p>
    {% endif %}
  </section>
  {% endif %}

  {# ── Detailed Findings ── #}
  {% if ctx.analysis.chains %}
  <section id="findings">
    <h2>Detailed Findings</h2>

    {% for chain in ctx.analysis.chains %}
    <article id="finding-{{ chain.id }}" class="finding {{ chain.severity|lower }}">
      <h2>{{ loop.index }}. {{ chain.name }}</h2>

      <div class="finding-meta">
        <span class="badge {{ chain.severity|lower }}">{{ chain.severity }}</span>
        <span>{{ chain.pattern_id }}</span>
        <span>{{ chain.owasp_category }}</span>
        <span>Confidence: {{ (chain.confidence.final_score * 100)|round(1) }}%</span>
      </div>

      <h3>Narrative</h3>
      <p class="narrative">{{ chain.narrative }}</p>

      <h3>Attack Steps</h3>
      <ol class="steps">
      {% for step in chain.steps %}
        <li class="step">
          <strong>Step {{ step.sequence }}: {{ step.method }} {{ step.path }}</strong>
          <table>
            <tr><th>Action</th>         <td>{{ step.action }}</td></tr>
            <tr><th>Auth required</th>  <td>{{ step.auth_required }}</td></tr>
            <tr><th>Attacker gains</th> <td>{{ step.attacker_gains }}</td></tr>
            <tr><th>Technique</th>      <td>{{ step.technique }}</td></tr>
          </table>
        </li>
      {% endfor %}
      </ol>

      <h3>Remediation</h3>
      <ol class="remediation">
      {% for fix in chain.remediation %}
        <li>{{ fix }}</li>
      {% endfor %}
      </ol>

      {% if chain.mitre_techniques %}
      <p class="mitre">MITRE ATT&amp;CK:
        {% for tid in chain.mitre_techniques %}<code>{{ tid }}</code>{% if not loop.last %}, {% endif %}{% endfor %}
      </p>
      {% endif %}

      <details class="confidence-details">
        <summary>Confidence Breakdown</summary>
        <table>
          <tr><th>Component</th><th>Score</th></tr>
          <tr><td>Graph match (pattern prior)</td>        <td>{{ (chain.confidence.graph_match_score * 100)|round(1) }}%</td></tr>
          <tr><td>Auth clarity (spec completeness)</td>   <td>{{ (chain.confidence.auth_clarity_score * 100)|round(1) }}%</td></tr>
          <tr><td>LLM self-assessment</td>                <td>{{ (chain.confidence.llm_self_score * 100)|round(1) }}%</td></tr>
          <tr><td>Evidence (tool calls)</td>              <td>{{ chain.confidence.evidence_count }}</td></tr>
          <tr><td><strong>Final score</strong></td>       <td><strong>{{ (chain.confidence.final_score * 100)|round(1) }}%</strong></td></tr>
        </table>
        <p><em>{{ chain.confidence.rationale }}</em></p>
      </details>

      {% if chain.tool_calls_used %}
      <details class="tool-calls">
        <summary>Graph tool calls ({{ chain.tool_calls_used|length }})</summary>
        <ul>{% for tc in chain.tool_calls_used %}<li><code>{{ tc }}</code></li>{% endfor %}</ul>
      </details>
      {% endif %}

      <p class="analyzed-at">
        Analyzed: {{ chain.analyzed_at.strftime('%Y-%m-%d %H:%M UTC') }}
        &nbsp;·&nbsp; Model: {{ chain.llm_model }}
        &nbsp;·&nbsp; {{ chain.tokens_used }} tokens
      </p>
    </article>
    {% endfor %}
  </section>
  {% else %}
  <section><p>No validated attack chains found for this specification.</p></section>
  {% endif %}

  {# ── Parse Warnings ── #}
  {% if ctx.analysis.parse_warnings %}
  <section id="warnings">
    <h2>Parse Warnings</h2>
    <ul>{% for w in ctx.analysis.parse_warnings %}<li>{{ w }}</li>{% endfor %}</ul>
  </section>
  {% endif %}

</div>{# end .page #}

{# ── D3.js Attack Graph ── #}
{% if ctx.include_graph and ctx.analysis.chain_count > 0 %}
<script src="https://d3js.org/d3.v7.min.js"></script>
<script>
(function () {
  "use strict";
  const data = {{ d3_graph_data|safe }};
  if (!data.nodes.length) return;

  const COLORS = {
    CRITICAL: "#dc2626", HIGH: "#ea580c",
    MEDIUM:   "#ca8a04", LOW: "#2563eb", INFO: "#6b7280"
  };

  const container = document.getElementById("attack-graph-container");
  const W = container.clientWidth || 900;
  const H = 520;

  const svg = d3.select("#attack-graph")
    .attr("width", W).attr("height", H);

  /* Arrow markers per severity */
  const defs = svg.append("defs");
  Object.entries(COLORS).forEach(([sev, color]) => {
    defs.append("marker")
      .attr("id", `arrow-${sev}`)
      .attr("viewBox", "0 -5 10 10")
      .attr("refX", 24).attr("refY", 0)
      .attr("markerWidth", 6).attr("markerHeight", 6)
      .attr("orient", "auto")
      .append("path").attr("d", "M0,-5L10,0L0,5").attr("fill", color);
  });

  const zoom = d3.zoom().scaleExtent([0.3, 4])
    .on("zoom", (e) => g.attr("transform", e.transform));
  svg.call(zoom);
  const g = svg.append("g");

  /* Tooltip */
  const tip = d3.select("body").append("div")
    .style("position", "absolute").style("background", "#0f172a")
    .style("color", "#f8fafc").style("padding", "6px 10px")
    .style("border-radius", "5px").style("font-size", "12px")
    .style("pointer-events", "none").style("opacity", 0);

  const sim = d3.forceSimulation(data.nodes)
    .force("link", d3.forceLink(data.links).id((d) => d.id).distance(180))
    .force("charge", d3.forceManyBody().strength(-400))
    .force("center", d3.forceCenter(W / 2, H / 2))
    .force("collision", d3.forceCollide(35));

  const link = g.append("g")
    .selectAll("line").data(data.links).join("line")
    .attr("stroke", (d) => COLORS[d.severity] || "#64748b")
    .attr("stroke-width", 2.5).attr("stroke-opacity", 0.8)
    .attr("marker-end", (d) => `url(#arrow-${d.severity})`);

  const node = g.append("g")
    .selectAll("circle").data(data.nodes).join("circle")
    .attr("r", 18)
    .attr("fill", (d) => COLORS[d.severity] || "#6b7280")
    .attr("stroke", "#fff").attr("stroke-width", 2.5)
    .call(
      d3.drag()
        .on("start", (e, d) => { if (!e.active) sim.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
        .on("drag",  (e, d) => { d.fx = e.x; d.fy = e.y; })
        .on("end",   (e, d) => { if (!e.active) sim.alphaTarget(0); d.fx = null; d.fy = null; })
    )
    .on("mouseover", (e, d) => {
      tip.style("opacity", 1).html(`<b>${d.label}</b><br/>${d.severity} · ${d.pattern_id || ""}`);
    })
    .on("mousemove", (e) => {
      tip.style("left", (e.pageX + 12) + "px").style("top", (e.pageY - 28) + "px");
    })
    .on("mouseout", () => tip.style("opacity", 0));

  const label = g.append("g")
    .selectAll("text").data(data.nodes).join("text")
    .text((d) => d.label.length > 22 ? d.label.slice(0, 21) + "…" : d.label)
    .attr("fill", "#f8fafc").attr("font-size", "9px")
    .attr("text-anchor", "middle").attr("dy", 32)
    .style("pointer-events", "none");

  sim.on("tick", () => {
    link.attr("x1", (d) => d.source.x).attr("y1", (d) => d.source.y)
        .attr("x2", (d) => d.target.x).attr("y2", (d) => d.target.y);
    node.attr("cx", (d) => d.x).attr("cy", (d) => d.y);
    label.attr("x", (d) => d.x).attr("y", (d) => d.y);
  });
})();
</script>
{% endif %}

<footer>
  <p>Generated by <strong>api-attack-path-analyzer {{ ctx.tool_version }}</strong>
     &nbsp;·&nbsp; Powered by Claude &nbsp;·&nbsp;
     <a href="https://owasp.org/API-Security/">OWASP API Security Top 10</a>
  </p>
</footer>

</body>
</html>
